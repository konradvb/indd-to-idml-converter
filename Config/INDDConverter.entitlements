<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<!-- Erlaubt der notarisierten App (mit Hardened Runtime), Apple Events an InDesign zu senden.
	     Ohne dieses Entitlement würde die InDesign-Steuerung nach der Notarisierung blockiert. -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
</dict>
</plist>
